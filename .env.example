# Copie ce fichier en .env et remplis avec ta vraie clé
# Ne committe JAMAIS le .env dans git

# Clé API Groq (https://console.groq.com/keys)
GROQ_API_KEY=gsk_xxxxx

# Optionnel : modèle Groq à utiliser
# Valeurs possibles :
#   llama-3.3-70b-versatile (défaut, bon compromis qualité/vitesse)
#   llama-3.1-8b-instant (plus rapide mais moins bon pour la créativité)
#   deepseek-r1-distill-llama-70b (raisonnement plus poussé, plus lent)
# GROQ_MODEL=llama-3.3-70b-versatile
