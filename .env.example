# Copie ce fichier en .env et remplis avec ta vraie clé
# Ne committe JAMAIS le .env dans git

# Clé API Groq (https://console.groq.com/keys)
GROQ_API_KEY=gsk_xxxxx

# Optionnel : modèle Groq à utiliser
# Valeurs possibles :
#   llama-3.3-70b-versatile (défaut, bon compromis qualité/vitesse)
#   llama-3.1-8b-instant (plus rapide mais moins bon pour la créativité)
#   deepseek-r1-distill-llama-70b (raisonnement plus poussé, plus lent)
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Médiathèque (optionnel) ---
# Bing Image Search (Azure Cognitive Services > Bing Search v7)
# https://portal.azure.com/ → créer une ressource "Bing Search v7"
# BING_SEARCH_KEY=

# Google Custom Search + YouTube Data API (même clé)
# 1. Créer un projet sur https://console.cloud.google.com/
# 2. Activer "Custom Search API" et "YouTube Data API v3"
# 3. Créer une clé API dans Identifiants
# 4. Pour les images : créer un moteur sur https://cse.google.com/ → copier l'ID (cx)
# GOOGLE_SEARCH_KEY=
# GOOGLE_SEARCH_CX=
